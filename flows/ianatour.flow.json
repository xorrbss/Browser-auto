{
  "name": "ianatour",
  "startUrl": "https://www.iana.org/domains",
  "steps": [
    { "kind": "find", "by": "role", "value": "link", "name": "Root Zone Management", "action": "click" },
    { "kind": "wait", "until": "url", "value": "**/domains/root" },
    { "kind": "find", "by": "role", "value": "link", "name": "Top-Level Domains", "action": "click" },
    { "kind": "wait", "until": "url", "value": "**/domains/root/db" },
    { "kind": "find", "by": "role", "value": "link", "name": ".abarth", "action": "click" },
    { "kind": "wait", "until": "url", "value": "**/domains/root/db/abarth.html" }
  ],
  "asserts": [
    { "kind": "url", "value": "**/domains/root/db/abarth.html" }
  ]
}
